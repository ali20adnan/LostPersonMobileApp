# Soniox API Configuration
SONIOX_API_KEY=your_api_key_here
SONIOX_WEBSOCKET_URL=wss://stt-rt.soniox.com/transcribe-websocket

# App Configuration
APP_NAME=الملاذ
DEFAULT_SOURCE_LANGUAGE=ar
DEFAULT_TARGET_LANGUAGE=en

# ── Backend ──────────────────────────────────────────────────────
# Production:
#   API_BASE_URL=https://api.almuntazer.net/losts/api
#   SERVER_BASE_URL=https://api.almuntazer.net/losts
#   FILES_BASE_URL=https://file.almuntazer.net/uploads/losts
#
# Local dev — Android Emulator (10.0.2.2 = host loopback alias):
#   API_BASE_URL=http://10.0.2.2:3003/api
#   SERVER_BASE_URL=http://10.0.2.2:3003
#   FILES_BASE_URL=http://10.0.2.2:3003/uploads/losts
#
# Local dev — iOS Simulator / web / desktop:
#   API_BASE_URL=http://localhost:3003/api
#   SERVER_BASE_URL=http://localhost:3003
#   FILES_BASE_URL=http://localhost:3003/uploads/losts
#
# Local dev — Physical device on the same Wi-Fi (replace with your host LAN IP):
#   API_BASE_URL=http://192.168.x.x:3003/api
#   SERVER_BASE_URL=http://192.168.x.x:3003
#   FILES_BASE_URL=http://192.168.x.x:3003/uploads/losts
API_BASE_URL=https://api.almuntazer.net/losts/api
SERVER_BASE_URL=https://api.almuntazer.net/losts
FILES_BASE_URL=https://file.almuntazer.net/uploads/losts

# Feature Flags
ENABLE_AUDIO_VISUALIZER=true
ENABLE_TTS=true
ENABLE_HISTORY=true

# LibreTranslate Configuration
LIBRE_TRANSLATE_URL=https://libretranslate.com/translate
LIBRE_TRANSLATE_API_KEY=
